{
  "name": "@pocket-code/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./messageHandler": {
      "import": "./dist/messageHandler.js",
      "require": "./dist/messageHandler.js",
      "types": "./dist/messageHandler.d.ts",
      "default": "./src/messageHandler.ts"
    },
    "./db": {
      "import": "./dist/db.js",
      "require": "./dist/db.js",
      "types": "./dist/db.d.ts",
      "default": "./src/db.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/google": "^1.2.0",
    "@ai-sdk/openai": "^1.2.0",
    "@anthropic-ai/claude-code": "^1.0.0",
    "ai": "^4.3.0",
    "dockerode": "^4.0.9",
    "dotenv": "^16.4.0",
    "jsonwebtoken": "^9.0.3",
    "sql.js": "^1.14.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
# SiliconFlow (硅基流动) — 推荐，支持 DeepSeek/Qwen 等模型，性价比高
# 注册: https://siliconflow.cn
SILICONFLOW_API_KEY=sk-xxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Anthropic (可选)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (可选)
OPENAI_API_KEY=sk-xxx

# Google Gemini (可选)
GOOGLE_GENERATIVE_AI_API_KEY=xxx

# Server
PORT=3100
WORKSPACE_ROOT=/tmp/pocket-code-workspaces

# Auth — 生产环境务必更换
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=30d

# Docker isolation (set to "true" to enable container isolation per user)
DOCKER_ENABLED=false
SANDBOX_IMAGE=pocket-code-sandbox:latest

# CLI 模式（可选）— 使用服务器本地已认证的 CLI 工具 Pro 订阅，无需 API Key
# 安装和认证: npm install -g @anthropic-ai/claude-code && claude login
# CLAUDE_CLI_PATH=/usr/local/bin/claude   # claude-code CLI 路径（默认: PATH 中的 claude）
# 安装和认证: npm install -g @google/gemini-cli && gemini auth login
# GEMINI_CLI_PATH=/usr/local/bin/gemini   # gemini CLI 路径（默认: PATH 中的 gemini）
# GEMINI_CLI_MODEL=gemini-2.5-pro         # Gemini CLI 使用的模型（可选）

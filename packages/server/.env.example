# SiliconFlow (硅基流动) — 推荐，支持 DeepSeek/Qwen 等模型，性价比高
# 注册: https://siliconflow.cn
SILICONFLOW_API_KEY=sk-xxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Anthropic (可选)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (可选)
OPENAI_API_KEY=sk-xxx

# Google Gemini (可选)
GOOGLE_GENERATIVE_AI_API_KEY=xxx

# Server
PORT=3100
WORKSPACE_ROOT=/tmp/pocket-code-workspaces

# Auth — 生产环境务必更换
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=30d

# Docker isolation (set to "true" to enable container isolation per user)
DOCKER_ENABLED=false
SANDBOX_IMAGE=pocket-code-sandbox:latest
CONTAINER_MEMORY=536870912
CONTAINER_CPU=0.5
IDLE_STOP_MS=300000
IDLE_REMOVE_MS=1800000

# Container Pool (requires DOCKER_ENABLED=true)
POOL_ENABLED=false
POOL_MIN_READY=2
POOL_MAX_TOTAL=10

# iFlow (心流) — GLM series
IFLOW_API_KEY=
IFLOW_BASE_URL=https://apis.iflow.cn/v1

# Agent
AGENT_MAX_STEPS=25

# Database (default: ~/.pocket-code/pocket-code.db)
DB_PATH=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# CLI 模式（可选）— 使用服务器本地已认证的 CLI 工具 Pro 订阅，无需 API Key
# 安装和认证: npm install -g @anthropic-ai/claude-code && claude login
# CLAUDE_CLI_PATH=/usr/local/bin/claude
# 安装和认证: npm install -g @google/gemini-cli && gemini auth login
# GEMINI_CLI_PATH=/usr/local/bin/gemini
# GEMINI_CLI_MODEL=gemini-2.5-pro
# GEMINI_CLI_EXTENSIONS=
